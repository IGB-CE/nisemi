generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  phone        String?    @unique
  firstName    String
  lastName     String
  passwordHash String?
  googleId     String?    @unique
  avatarUrl    String?
  role         Role       @default(PASSENGER)
  status       UserStatus @default(ACTIVE)
  gender       Gender     @default(UNSPECIFIED)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  driverProfile    DriverProfile?
  tripsAsDriver    Trip[]         @relation("DriverTrips")
  reservations     Reservation[]
  reviewsGiven     Review[]       @relation("ReviewsGiven")
  reviewsReceived  Review[]       @relation("ReviewsReceived")
  passengerRatingsGiven    PassengerRating[] @relation("PassengerRatingsByDriver")
  passengerRatingsReceived PassengerRating[] @relation("PassengerRatingsReceived")
  pushTokens       PushToken[]
  reportsBy        Report[]       @relation("ReportsBy")
  reportsAgainst   Report[]       @relation("ReportsAgainst")
  messagesSent     Message[]      @relation("MessagesSent")
  messagesReceived Message[]      @relation("MessagesReceived")
  rideAlerts       RideAlert[]
  blocksMade       Block[]        @relation("BlocksMade")
  blocksReceived   Block[]        @relation("BlocksReceived")
  conversationDeletions ConversationDeletion[]
  hiddenTrips      TripHistoryHidden[]
}

model ConversationDeletion {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  tripId    String
  otherId   String
  deletedAt DateTime @default(now())

  @@unique([userId, tripId, otherId])
  @@index([userId])
}

model TripHistoryHidden {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id])
  tripId   String
  trip     Trip     @relation(fields: [tripId], references: [id])
  hiddenAt DateTime @default(now())

  @@unique([userId, tripId])
  @@index([userId])
}

model Block {
  id        String   @id @default(cuid())
  blockerId String
  blocker   User     @relation("BlocksMade", fields: [blockerId], references: [id])
  blockedId String
  blocked   User     @relation("BlocksReceived", fields: [blockedId], references: [id])
  createdAt DateTime @default(now())

  @@unique([blockerId, blockedId])
  @@index([blockedId])
}

model RideAlert {
  id              String    @id @default(cuid())
  passengerId     String
  passenger       User      @relation(fields: [passengerId], references: [id])
  originLat       Float
  originLng       Float
  originLabel     String
  destLat         Float
  destLng         Float
  destLabel       String
  date            DateTime?
  searchRadiusM   Int       @default(500)
  tripType        TripType?
  active          Boolean   @default(true)
  expiresAt       DateTime
  notifiedTripIds String[]  @default([])
  createdAt       DateTime  @default(now())

  @@index([passengerId, active])
  @@index([active, expiresAt])
}

enum Role {
  PASSENGER
  DRIVER
  ADMIN
}

enum UserStatus {
  PENDING
  ACTIVE
  BLOCKED
}

enum Gender {
  MALE
  FEMALE
  UNSPECIFIED
}

enum GenderRestriction {
  ANY
  FEMALE_ONLY
  MALE_ONLY
}

enum DriverVerificationStatus {
  UNVERIFIED
  PENDING
  APPROVED
  REJECTED
}

model DriverProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id])
  carModel    String
  carColor    String
  carPlate    String
  carPhotoUrl String?
  rating      Float    @default(0)
  totalTrips  Int      @default(0)

  licenseUrl         String?
  verificationStatus DriverVerificationStatus @default(UNVERIFIED)
  verifiedAt         DateTime?
  rejectionReason    String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model City {
  id           String  @id @default(cuid())
  name         String  @unique
  nameAlbanian String?
  lat          Float?
  lng          Float?

  tripsAsOrigin      Trip[] @relation("TripOrigin")
  tripsAsDestination Trip[] @relation("TripDestination")
}

model Trip {
  id           String  @id @default(cuid())
  driverId     String
  driver       User    @relation("DriverTrips", fields: [driverId], references: [id])
  originCityId String?
  originCity   City?   @relation("TripOrigin", fields: [originCityId], references: [id])
  destCityId   String?
  destCity     City?   @relation("TripDestination", fields: [destCityId], references: [id])

  originLat   Float?
  originLng   Float?
  originLabel String?
  destLat     Float?
  destLng     Float?
  destLabel   String?

  routePolyline  String?
  routeDistanceM Int?
  routeDurationS Int?
  routeAltIndex  Int     @default(0)

  tripType          TripType?
  maxDetourM        Int               @default(500)
  genderRestriction GenderRestriction @default(ANY)

  departureAt    DateTime
  pricePerSeat   Decimal
  totalSeats     Int
  seatsAvailable Int
  status         TripStatus @default(SCHEDULED)
  notes          String?
  boostedUntil   DateTime?
  startedAt      DateTime?
  endedAt        DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  reservations     Reservation[]
  messages         Message[]
  reviews          Review[]
  passengerRatings PassengerRating[]
  locations        TripLocation[]
  hiddenBy         TripHistoryHidden[]
}

enum TripStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TripType {
  INTERCITY
  INTRACITY
}

model TripLocation {
  id         String   @id @default(cuid())
  tripId     String
  trip       Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  lat        Float
  lng        Float
  heading    Float?
  speed      Float?
  accuracy   Float?
  recordedAt DateTime
  createdAt  DateTime @default(now())

  @@index([tripId, recordedAt])
}

model Reservation {
  id          String            @id @default(cuid())
  tripId      String
  trip        Trip              @relation(fields: [tripId], references: [id])
  passengerId String
  passenger   User              @relation(fields: [passengerId], references: [id])
  seats       Int               @default(1)
  status      ReservationStatus @default(PENDING)

  pickupLat    Float?
  pickupLng    Float?
  pickupLabel  String?
  dropoffLat   Float?
  dropoffLng   Float?
  dropoffLabel String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ReservationStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
  REMOVED
}

model Review {
  id        String   @id @default(cuid())
  tripId    String
  trip      Trip     @relation(fields: [tripId], references: [id])
  authorId  String
  author    User     @relation("ReviewsGiven", fields: [authorId], references: [id])
  targetId  String
  target    User     @relation("ReviewsReceived", fields: [targetId], references: [id])
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  @@unique([tripId, authorId])
}

model PassengerRating {
  id          String   @id @default(cuid())
  tripId      String
  trip        Trip     @relation(fields: [tripId], references: [id])
  driverId    String
  driver      User     @relation("PassengerRatingsByDriver", fields: [driverId], references: [id])
  passengerId String
  passenger   User     @relation("PassengerRatingsReceived", fields: [passengerId], references: [id])
  liked       Boolean
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tripId, passengerId])
  @@index([passengerId])
}

model Report {
  id         String       @id @default(cuid())
  reporterId String
  reporter   User         @relation("ReportsBy", fields: [reporterId], references: [id])
  reportedId String
  reported   User         @relation("ReportsAgainst", fields: [reportedId], references: [id])
  reason     String
  status     ReportStatus @default(OPEN)
  createdAt  DateTime     @default(now())
}

enum ReportStatus {
  OPEN
  RESOLVED
  DISMISSED
}

model Broadcast {
  id             String   @id @default(cuid())
  title          String
  body           String
  audience       String
  recipientCount Int
  sentById       String
  sentByName     String
  createdAt      DateTime @default(now())

  @@index([createdAt])
}

model PushToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  token     String   @unique
  platform  String
  createdAt DateTime @default(now())
}

model Message {
  id         String   @id @default(cuid())
  tripId     String
  trip       Trip     @relation(fields: [tripId], references: [id])
  senderId   String
  sender     User     @relation("MessagesSent", fields: [senderId], references: [id])
  receiverId String
  receiver   User     @relation("MessagesReceived", fields: [receiverId], references: [id])
  content    String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([tripId, senderId, receiverId])
  @@index([receiverId, read])
}
