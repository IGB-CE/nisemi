EXPO_PUBLIC_API_URL=http://YOUR_LAN_IP:4000

# AdMob app IDs — leave empty in development to use Google's test app IDs.
# Set real IDs only for production builds (from admob.google.com).
ADMOB_ANDROID_APP_ID=
ADMOB_IOS_APP_ID=

# AdMob ad unit IDs — leave empty in development to use TestIds from the SDK.
# Set real ad unit IDs only for production builds.
EXPO_PUBLIC_ADMOB_REWARDED_ANDROID=
EXPO_PUBLIC_ADMOB_REWARDED_IOS=
EXPO_PUBLIC_ADMOB_INTERSTITIAL_ANDROID=
EXPO_PUBLIC_ADMOB_INTERSTITIAL_IOS=
