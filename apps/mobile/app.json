{
  "expo": {
    "name": "Nisemi",
    "slug": "albania-rides",
    "scheme": "nisemi",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/46fc22b5-77f1-4034-afb9-fe6e84e582e3"
    },
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "al.nisemi.app",
      "splash": {
        "image": "./assets/splash-icon.png",
        "resizeMode": "contain",
        "backgroundColor": "#FFFFFF",
        "dark": {
          "image": "./assets/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#0D0D0D"
        }
      },
      "infoPlist": {
        "NSUserNotificationUsageDescription": "Nisemi dërgon njoftime për rezervimet tuaja.",
        "NSLocationWhenInUseUsageDescription": "Nisemi përdor vendndodhjen tuaj për të ndarë pozicionin tuaj me pasagjerët gjatë udhëtimit.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Nisemi vazhdon të ndajë vendndodhjen tuaj me pasagjerët edhe kur aplikacioni është në sfond gjatë udhëtimit.",
        "UIBackgroundModes": ["location", "fetch"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D0D0D"
      },
      "splash": {
        "image": "./assets/splash-icon.png",
        "resizeMode": "contain",
        "backgroundColor": "#FFFFFF",
        "dark": {
          "image": "./assets/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#0D0D0D"
        }
      },
      "package": "al.nisemi.app",
      "googleServicesFile": "./google-services.json",
      "edgeToEdgeEnabled": true,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#DC2626",
          "androidMode": "default"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Nisemi vazhdon të ndajë vendndodhjen tuaj me pasagjerët edhe kur aplikacioni është në sfond gjatë udhëtimit.",
          "locationWhenInUsePermission": "Nisemi përdor vendndodhjen tuaj për të ndarë pozicionin tuaj me pasagjerët gjatë udhëtimit.",
          "isIosBackgroundLocationEnabled": true,
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "46fc22b5-77f1-4034-afb9-fe6e84e582e3"
      }
    },
    "owner": "bledi-nisemi"
  }
}
